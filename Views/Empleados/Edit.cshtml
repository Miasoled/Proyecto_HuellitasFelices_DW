@model HuellitasFelices.Models.Empleado
@{ ViewData["Title"] = "Editar empleado"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Empleados</a></li>
        <li class="breadcrumb-item active">Editar</li>
    </ol></nav>
    <h1><i class="bi bi-pencil-square me-2"></i>Editar empleado</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-person-badge me-2"></i>@Model.Nombre</div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FechaCreacion" />
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Nombre" class="form-label"><i class="bi bi-person me-1"></i>Nombre completo</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Cargo" class="form-label"><i class="bi bi-briefcase me-1"></i>Cargo</label>
                        <select asp-for="Cargo" class="form-select">
                            <option>Veterinario</option><option>Asistente</option>
                            <option>Recepcionista</option><option>Auxiliar</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Telefono" class="form-label"><i class="bi bi-phone me-1"></i>Teléfono</label>
                        <input asp-for="Telefono" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Salario" class="form-label"><i class="bi bi-cash-stack me-1"></i>Salario ($)</label>
                        <input asp-for="Salario" class="form-control" type="number" step="0.01" />
                    </div>
                    <div class="col-12 d-flex gap-3 pt-2">
                        <button type="submit" class="btn-primary-hf"><i class="bi bi-check-lg"></i> Guardar cambios</button>
                        <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Cancelar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div></div></div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
