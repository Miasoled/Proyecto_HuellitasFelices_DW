@model HuellitasFelices.Models.Consulta
@{ ViewData["Title"] = "Eliminar consulta"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Consultas</a></li>
        <li class="breadcrumb-item active">Eliminar</li>
    </ol></nav>
    <h1><i class="bi bi-trash3-fill me-2"></i>Eliminar consulta</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="hf-card" style="border:1.5px solid #fca5a5">
        <div style="background:linear-gradient(135deg,#dc2626,#ef4444);color:white;padding:16px 20px;font-weight:700;font-size:.95rem;display:flex;align-items:center;gap:8px;border-radius:19px 19px 0 0">
            <i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación
        </div>
        <div class="card-body p-4">
            <p class="text-center text-muted mb-3">El registro se marcará como inactivo (eliminación lógica).</p>
            <div style="background:var(--gray-50);border-radius:12px;padding:16px;margin-bottom:20px">
                <div class="row g-2">
                    <div class="col-12"><small class="text-muted d-block">Motivo</small><strong>@Model.Motivo</strong></div>
                    <div class="col-6"><small class="text-muted d-block">Costo</small><strong>$@Model.Costo.ToString("N2")</strong></div>
                    <div class="col-6"><small class="text-muted d-block">Mascota</small><strong>@Model.Mascota?.Especie</strong></div>
                </div>
            </div>
            <form asp-action="Delete" method="post" class="d-flex gap-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" style="background:#dc2626;color:white;border:none;padding:11px 24px;border-radius:10px;font-weight:600;display:flex;align-items:center;gap:7px">
                    <i class="bi bi-trash3-fill"></i> Confirmar
                </button>
                <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Cancelar</a>
            </form>
        </div>
    </div>
</div></div></div></div>
