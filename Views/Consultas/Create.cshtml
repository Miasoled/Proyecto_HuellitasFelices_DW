@model HuellitasFelices.Models.Consulta
@{ ViewData["Title"] = "Nueva consulta"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Consultas</a></li>
        <li class="breadcrumb-item active">Nueva</li>
    </ol></nav>
    <h1><i class="bi bi-calendar-plus-fill me-2"></i>Nueva consulta</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-clipboard2-pulse me-2"></i>Datos de la consulta</div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label"><i class="bi bi-patch-heart me-1"></i>Mascota (Nombre)</label>
                        <input type="text" name="NombreMascota" class="form-control" placeholder="Ingrese el nombre de la mascota (Ej: Max, Luna)..." required />
                        <span asp-validation-for="MascotaId" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Motivo" class="form-label"><i class="bi bi-chat-left-text me-1"></i>Motivo</label>
                        <input asp-for="Motivo" class="form-control" placeholder="Ej: Vacunación anual" />
                        <span asp-validation-for="Motivo" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Diagnostico" class="form-label"><i class="bi bi-clipboard2-check me-1"></i>Diagnóstico</label>
                        <textarea asp-for="Diagnostico" class="form-control" rows="3" placeholder="Descripción del diagnóstico…"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Costo" class="form-label"><i class="bi bi-cash me-1"></i>Costo ($)</label>
                        <input asp-for="Costo" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Costo" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FechaConsulta" class="form-label"><i class="bi bi-calendar3 me-1"></i>Fecha de consulta</label>
                        <input asp-for="FechaConsulta" class="form-control" type="datetime-local" />
                    </div>
                    <div class="col-12 d-flex gap-3 pt-2">
                        <button type="submit" class="btn-primary-hf"><i class="bi bi-check-lg"></i> Guardar</button>
                        <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Cancelar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div></div></div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
