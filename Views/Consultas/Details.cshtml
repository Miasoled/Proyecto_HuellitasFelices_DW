@model HuellitasFelices.Models.Consulta
@{ ViewData["Title"] = "Detalle de consulta"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Consultas</a></li>
        <li class="breadcrumb-item active">Detalle</li>
    </ol></nav>
    <h1><i class="bi bi-clipboard2-pulse-fill me-2"></i>Detalle de consulta</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-clipboard2-pulse me-2"></i>@Model.Motivo</div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-12"><small class="text-muted d-block"><i class="bi bi-chat-left-text me-1"></i>Motivo</small><strong>@Model.Motivo</strong></div>
                <div class="col-12"><small class="text-muted d-block"><i class="bi bi-clipboard2-check me-1"></i>Diagnóstico</small><p style="margin:0">@(Model.Diagnostico ?? "—")</p></div>
                <div class="col-md-4"><small class="text-muted d-block"><i class="bi bi-cash me-1"></i>Costo</small><span class="badge-success-hf">$@Model.Costo.ToString("N2")</span></div>
                <div class="col-md-4"><small class="text-muted d-block"><i class="bi bi-patch-heart me-1"></i>Mascota</small><strong>@(Model.Mascota?.Especie ?? "—")</strong></div>
                <div class="col-md-4"><small class="text-muted d-block"><i class="bi bi-calendar3 me-1"></i>Fecha</small><strong>@Model.FechaConsulta.ToLocalTime().ToString("dd/MM/yyyy")</strong></div>
            </div>
        </div>
        <div style="padding:16px 24px;border-top:1px solid var(--border);display:flex;gap:10px">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-hf"><i class="bi bi-pencil"></i> Editar</a>
            <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Volver</a>
        </div>
    </div>
</div></div></div></div>
