@model HuellitasFelices.Models.Pago
@{ ViewData["Title"] = "Nuevo pago"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Pagos</a></li>
        <li class="breadcrumb-item active">Nuevo</li>
    </ol></nav>
    <h1><i class="bi bi-credit-card-fill me-2"></i>Nuevo pago</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-credit-card me-2"></i>Datos del pago</div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="DuenoId" class="form-label"><i class="bi bi-person me-1"></i>Dueño</label>
                        <select asp-for="DuenoId" asp-items="ViewBag.DuenoId" class="form-select">
                            <option value="">-- Seleccione un dueño --</option>
                        </select>
                        <span asp-validation-for="DuenoId" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Monto" class="form-label"><i class="bi bi-cash me-1"></i>Monto ($)</label>
                        <input asp-for="Monto" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        <span asp-validation-for="Monto" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MetodoPago" class="form-label"><i class="bi bi-wallet2 me-1"></i>Método de pago</label>
                        <select asp-for="MetodoPago" class="form-select">
                            <option value="">-- Seleccione --</option>
                            <option>Efectivo</option>
                            <option>Tarjeta</option>
                            <option>Transferencia</option>
                        </select>
                        <span asp-validation-for="MetodoPago" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Estado" class="form-label"><i class="bi bi-flag me-1"></i>Estado</label>
                        <select asp-for="Estado" class="form-select">
                            <option>Pendiente</option>
                            <option>Pagado</option>
                            <option>Anulado</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FechaPago" class="form-label"><i class="bi bi-calendar3 me-1"></i>Fecha de pago</label>
                        <input asp-for="FechaPago" class="form-control" type="datetime-local" />
                    </div>
                    <div class="col-12 d-flex gap-3 pt-2">
                        <button type="submit" class="btn-primary-hf"><i class="bi bi-check-lg"></i> Guardar</button>
                        <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Cancelar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div></div></div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
