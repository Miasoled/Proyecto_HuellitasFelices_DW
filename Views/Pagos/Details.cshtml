@model HuellitasFelices.Models.Pago
@{ ViewData["Title"] = "Detalle de pago"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Pagos</a></li>
        <li class="breadcrumb-item active">Detalle</li>
    </ol></nav>
    <h1><i class="bi bi-credit-card-fill me-2"></i>Pago #@Model.Id</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-credit-card me-2"></i>Detalle del pago</div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <small class="text-muted d-block"><i class="bi bi-cash me-1"></i>Monto</small>
                    <span style="font-size:1.6rem; font-weight:800; color:var(--primary)">$@Model.Monto.ToString("N2")</span>
                </div>
                <div class="col-md-6">
                    <small class="text-muted d-block"><i class="bi bi-flag me-1"></i>Estado</small>
                    @{
                        var cls = Model.Estado switch { "Pagado"=>"badge-success-hf","Anulado"=>"badge-danger-hf",_=>"badge-warning-hf" };
                    }
                    <span class="@cls" style="font-size:.9rem">@Model.Estado</span>
                </div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-wallet2 me-1"></i>Método</small><span class="badge-info-hf">@Model.MetodoPago</span></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-person me-1"></i>Dueño</small><strong>@(Model.Dueno?.Nombre ?? "—")</strong></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-calendar3 me-1"></i>Fecha de pago</small><strong>@Model.FechaPago.ToLocalTime().ToString("dd/MM/yyyy")</strong></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-calendar me-1"></i>Fecha de registro</small><strong>@Model.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</strong></div>
            </div>
        </div>
        <div style="padding:16px 24px;border-top:1px solid var(--border);display:flex;gap:10px">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-hf"><i class="bi bi-pencil"></i> Editar</a>
            <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Volver</a>
        </div>
    </div>
</div></div></div></div>
