@model HuellitasFelices.Models.Dueno
@{ ViewData["Title"] = "Eliminar dueño"; }

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Dueños</a></li>
            <li class="breadcrumb-item active">Eliminar</li>
        </ol></nav>
        <h1><i class="bi bi-trash3-fill me-2"></i>Eliminar dueño</h1>
    </div>
</div>

<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-6">
    <div class="hf-card" style="border:1.5px solid #fca5a5">
        <div style="background:linear-gradient(135deg,#dc2626,#ef4444); color:white; padding:16px 20px; font-weight:700; font-size:.95rem; display:flex; align-items:center; gap:8px; border-radius:19px 19px 0 0">
            <i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación lógica
        </div>
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <div style="width:60px;height:60px;background:#fee2e2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px">
                    <i class="bi bi-person-x-fill" style="font-size:1.8rem; color:#dc2626"></i>
                </div>
                <p style="color:var(--text-soft)">
                    El registro <strong>no será eliminado permanentemente</strong>.
                    Se marcará como inactivo y ya no aparecerá en los listados.
                </p>
            </div>
            <div style="background:var(--gray-50); border-radius:12px; padding:16px; margin-bottom:20px">
                <div class="row g-2">
                    <div class="col-6">
                        <small class="text-muted d-block">Nombre</small>
                        <strong>@Model.Nombre</strong>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block">Teléfono</small>
                        <strong>@Model.Telefono</strong>
                    </div>
                    <div class="col-12">
                        <small class="text-muted d-block">Email</small>
                        <strong>@(Model.Email ?? "—")</strong>
                    </div>
                </div>
            </div>
            <form asp-action="Delete" method="post" class="d-flex gap-3">
                <input type="hidden" asp-for="Id" />
                <button type="submit" style="background:#dc2626;color:white;border:none;padding:11px 24px;border-radius:10px;font-weight:600;display:flex;align-items:center;gap:7px;transition:background .2s" onmouseover="this.style.background='#b91c1c'" onmouseout="this.style.background='#dc2626'">
                    <i class="bi bi-trash3-fill"></i> Confirmar eliminación
                </button>
                <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Cancelar</a>
            </form>
        </div>
    </div>
</div></div>
</div></div>
