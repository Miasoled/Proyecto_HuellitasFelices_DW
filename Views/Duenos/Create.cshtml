@model HuellitasFelices.Models.Dueno
@{ ViewData["Title"] = "Nuevo dueño"; }

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Dueños</a></li>
            <li class="breadcrumb-item active">Nuevo</li>
        </ol></nav>
        <h1><i class="bi bi-person-plus-fill me-2"></i>Nuevo dueño</h1>
    </div>
</div>

<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-person-fill me-2"></i>Información del dueño</div>
        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Nombre" class="form-label"><i class="bi bi-person me-1"></i>Nombre completo</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan Pérez" />
                        <span asp-validation-for="Nombre" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Telefono" class="form-label"><i class="bi bi-phone me-1"></i>Teléfono</label>
                        <input asp-for="Telefono" class="form-control" placeholder="0991234567" />
                        <span asp-validation-for="Telefono" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Correo electrónico</label>
                        <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                        <span asp-validation-for="Email" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Direccion" class="form-label"><i class="bi bi-geo-alt me-1"></i>Dirección</label>
                        <input asp-for="Direccion" class="form-control" placeholder="Av. Principal 123" />
                        <span asp-validation-for="Direccion" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-12 d-flex gap-3 pt-2">
                        <button type="submit" class="btn-primary-hf"><i class="bi bi-check-lg"></i> Guardar</button>
                        <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Cancelar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div></div>
</div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
