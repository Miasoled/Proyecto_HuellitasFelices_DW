@model HuellitasFelices.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Crear cuenta"; }

<div style="background:var(--gray-50); min-height:calc(100vh - 120px); display:flex; align-items:center; padding:40px 16px">
    <div style="width:100%; max-width:480px; margin:0 auto">
        <div class="login-card">
            <div class="login-card-header">
                <div style="width:56px;height:56px;background:rgba(255,255,255,.2);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px">
                    <i class="bi bi-person-plus-fill" style="font-size:1.6rem; color:white"></i>
                </div>
                <h4>Crear cuenta de cliente</h4>
                <p>Agenda citas, solicita adopciones y más</p>
            </div>
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NombreCompleto" class="form-label"><i class="bi bi-person me-1"></i>Nombre completo</label>
                        <input asp-for="NombreCompleto" class="form-control" placeholder="Juan Pérez" />
                        <span asp-validation-for="NombreCompleto" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Correo electrónico</label>
                        <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                        <span asp-validation-for="Email" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label"><i class="bi bi-phone me-1"></i>Teléfono</label>
                        <input asp-for="Telefono" class="form-control" placeholder="0991234567" />
                        <span asp-validation-for="Telefono" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label asp-for="Password" class="form-label"><i class="bi bi-lock me-1"></i>Contraseña</label>
                            <input asp-for="Password" class="form-control" placeholder="Mín. 8 caracteres" />
                            <span asp-validation-for="Password" class="text-danger" style="font-size:.82rem"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="ConfirmPassword" class="form-label"><i class="bi bi-lock-fill me-1"></i>Confirmar</label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Repite la contraseña" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.82rem"></span>
                        </div>
                    </div>
                    <button type="submit" class="btn-primary-hf w-100 justify-content-center" style="padding:13px">
                        <i class="bi bi-person-check-fill"></i> Crear mi cuenta
                    </button>
                </form>
            </div>
            <div style="padding:16px 32px 24px; text-align:center; border-top:1px solid var(--border)">
                <span style="color:var(--text-soft); font-size:.9rem">¿Ya tienes cuenta?</span>
                <a asp-action="Login" class="btn-outline-hf ms-2" style="padding:7px 16px; font-size:.88rem">
                    <i class="bi bi-box-arrow-in-right"></i> Iniciar sesión
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
