@model HuellitasFelices.ViewModels.RegisterInternoViewModel
@{ ViewData["Title"] = "Nuevo usuario interno"; }

<div style="background:var(--gray-50); min-height:calc(100vh - 120px); display:flex; align-items:center; padding:40px 16px">
    <div style="width:100%; max-width:480px; margin:0 auto">
        <div class="login-card">
            <div class="login-card-header">
                <div style="width:52px;height:52px;background:rgba(255,255,255,.2);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px">
                    <i class="bi bi-shield-lock-fill" style="font-size:1.5rem; color:white"></i>
                </div>
                <h4>Crear usuario interno</h4>
                <p>Solo visible para Administradores</p>
            </div>
            <div class="card-body">
                <form asp-action="RegisterInterno" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Correo electrónico</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label asp-for="Password" class="form-label"><i class="bi bi-lock me-1"></i>Contraseña</label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger" style="font-size:.82rem"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="ConfirmPassword" class="form-label"><i class="bi bi-lock-fill me-1"></i>Confirmar</label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:.82rem"></span>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Rol" class="form-label"><i class="bi bi-shield-check me-1"></i>Rol del sistema</label>
                        <select asp-for="Rol" asp-items="ViewBag.Roles" class="form-select">
                            <option value="">-- Seleccione un rol --</option>
                        </select>
                        <span asp-validation-for="Rol" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <button type="submit" class="btn-primary-hf w-100 justify-content-center" style="padding:13px">
                        <i class="bi bi-person-check-fill"></i> Crear usuario
                    </button>
                </form>
            </div>
            <div style="padding:14px 32px 20px; border-top:1px solid var(--border); text-align:center">
                <a asp-action="Usuarios" class="btn-outline-hf" style="padding:7px 16px; font-size:.88rem">
                    <i class="bi bi-arrow-left"></i> Ver todos los usuarios
                </a>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
