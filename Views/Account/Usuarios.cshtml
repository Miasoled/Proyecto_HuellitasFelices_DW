@model List<(Microsoft.AspNetCore.Identity.IdentityUser usuario, IList<string> roles)>
@{ ViewData["Title"] = "Usuarios"; }

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
            <li class="breadcrumb-item active">Usuarios</li>
        </ol></nav>
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="bi bi-people-fill me-2"></i>Usuarios del sistema</h1>
                <small style="opacity:.8">@Model.Count usuarios registrados</small>
            </div>
            <a asp-action="RegisterInterno" class="btn-hero-primary">
                <i class="bi bi-person-plus-fill"></i> Nuevo usuario interno
            </a>
        </div>
    </div>
</div>

<div class="content-wrapper"><div class="container">
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success mb-4"><i class="bi bi-check-circle-fill me-2"></i>@TempData["Mensaje"]</div>
    }

    <div class="hf-card">
        <div class="table-responsive">
            <table class="hf-table">
                <thead><tr>
                    <th><i class="bi bi-envelope me-1"></i>Email</th>
                    <th><i class="bi bi-shield-check me-1"></i>Rol(es)</th>
                    <th><i class="bi bi-check-circle me-1"></i>Estado</th>
                </tr></thead>
                <tbody>
                    @foreach (var (usuario, roles) in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:36px;height:36px;background:var(--primary-bg);border-radius:50%;display:flex;align-items:center;justify-content:center">
                                        <i class="bi bi-person-fill text-success"></i>
                                    </div>
                                    <span style="font-weight:500">@usuario.Email</span>
                                </div>
                            </td>
                            <td>
                                @foreach (var rol in roles)
                                {
                                    var cls = rol switch {
                                        "Administrador" => "badge-danger-hf",
                                        "Supervisor"    => "badge-info-hf",
                                        "Operador"      => "badge-warning-hf",
                                        _               => "badge-success-hf"
                                    };
                                    <span class="@cls me-1">@rol</span>
                                }
                            </td>
                            <td>
                                @if (usuario.EmailConfirmed)
                                { <span class="badge-success-hf"><i class="bi bi-check2 me-1"></i>Activo</span> }
                                else
                                { <span class="badge-warning-hf"><i class="bi bi-clock me-1"></i>Pendiente</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div></div>
