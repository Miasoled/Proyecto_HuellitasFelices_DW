@model ErrorViewModel
@{ ViewData["Title"] = "Error"; }

<div class="content-wrapper" style="min-height:calc(100vh - 120px); display:flex; align-items:center; padding:40px 16px">
    <div style="width:100%; max-width:560px; margin:0 auto; text-align:center">
        <div style="width:80px;height:80px;background:#fee2e2;border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 24px">
            <i class="bi bi-bug-fill" style="font-size:2.5rem; color:#dc2626"></i>
        </div>
        <h2 style="font-weight:800; color:var(--text-dark); margin-bottom:12px">Ha ocurrido un error</h2>
        <p style="color:var(--text-soft); font-size:1rem; line-height:1.7; margin-bottom:24px">
            Lo sentimos, se produjo un error inesperado al procesar tu solicitud. 
            El equipo técnico ha sido notificado del inconveniente.
        </p>

        @if (Model.ShowRequestId)
        {
            <div class="p-3 mb-4 rounded-3 text-start" style="background:#f3f4f6; border:1px solid var(--border); font-family:monospace; font-size:.88rem">
                <span class="text-muted">ID de Solicitud:</span> <strong>@Model.RequestId</strong>
            </div>
        }

        <div class="d-flex justify-content-center gap-3">
            <a href="javascript:history.back()" class="btn-outline-hf">
                <i class="bi bi-arrow-left"></i> Regresar
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn-primary-hf">
                <i class="bi bi-house"></i> Ir al Inicio
            </a>
        </div>
    </div>
</div>
