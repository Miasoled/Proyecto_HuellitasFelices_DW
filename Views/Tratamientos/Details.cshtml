@model HuellitasFelices.Models.Tratamiento
@{ ViewData["Title"] = "Detalle de tratamiento"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Tratamientos</a></li>
        <li class="breadcrumb-item active">Detalle</li>
    </ol></nav>
    <h1><i class="bi bi-capsule-pill me-2"></i>@Model.Nombre</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-capsule me-2"></i>Información del tratamiento</div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-12"><small class="text-muted d-block"><i class="bi bi-tag me-1"></i>Nombre</small><strong>@Model.Nombre</strong></div>
                <div class="col-12"><small class="text-muted d-block"><i class="bi bi-chat-left-dots me-1"></i>Descripción</small><p style="margin:0">@(Model.Descripcion ?? "—")</p></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-capsule me-1"></i>Medicamento</small><span class="badge-warning-hf">@(Model.Medicamento ?? "—")</span></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-cash me-1"></i>Costo</small><span class="badge-success-hf">$@Model.Costo.ToString("N2")</span></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-clipboard2-pulse me-1"></i>Consulta ID</small><strong>#@Model.ConsultaId</strong></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-calendar3 me-1"></i>Fecha de registro</small><strong>@Model.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")</strong></div>
            </div>
        </div>
        <div style="padding:16px 24px;border-top:1px solid var(--border);display:flex;gap:10px">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-hf"><i class="bi bi-pencil"></i> Editar</a>
            <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Volver</a>
        </div>
    </div>
</div></div></div></div>
