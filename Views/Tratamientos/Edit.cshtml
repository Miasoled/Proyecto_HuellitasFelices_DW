@model HuellitasFelices.Models.Tratamiento
@{ ViewData["Title"] = "Editar tratamiento"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Tratamientos</a></li>
        <li class="breadcrumb-item active">Editar</li>
    </ol></nav>
    <h1><i class="bi bi-pencil-square me-2"></i>Editar tratamiento</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-capsule me-2"></i>@Model.Nombre</div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FechaCreacion" />
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="ConsultaId" class="form-label"><i class="bi bi-clipboard2-pulse me-1"></i>Consulta</label>
                        <select asp-for="ConsultaId" asp-items="ViewBag.ConsultaId" class="form-select"></select>
                    </div>
                    <div class="col-12">
                        <label asp-for="Nombre" class="form-label"><i class="bi bi-tag me-1"></i>Nombre</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Descripcion" class="form-label"><i class="bi bi-chat-left-dots me-1"></i>Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Medicamento" class="form-label"><i class="bi bi-capsule me-1"></i>Medicamento</label>
                        <input asp-for="Medicamento" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Costo" class="form-label"><i class="bi bi-cash me-1"></i>Costo ($)</label>
                        <input asp-for="Costo" class="form-control" type="number" step="0.01" />
                    </div>
                    <div class="col-12 d-flex gap-3 pt-2">
                        <button type="submit" class="btn-primary-hf"><i class="bi bi-check-lg"></i> Guardar cambios</button>
                        <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Cancelar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div></div></div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
