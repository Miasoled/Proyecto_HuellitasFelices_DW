@model HuellitasFelices.Models.SolicitudAdopcion
@{ ViewData["Title"] = "Detalle de solicitud"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Solicitudes</a></li>
        <li class="breadcrumb-item active">Detalle</li>
    </ol></nav>
    <h1><i class="bi bi-file-earmark-check-fill me-2"></i>@Model.NombreSolicitante</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-file-earmark-text me-2"></i>Detalle de la solicitud</div>
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-12"><small class="text-muted d-block"><i class="bi bi-person me-1"></i>Solicitante</small><strong>@Model.NombreSolicitante</strong></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-phone me-1"></i>Teléfono</small><strong>@Model.Telefono</strong></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-envelope me-1"></i>Email</small><strong>@(Model.Email ?? "—")</strong></div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-house-heart me-1"></i>Animal</small><strong>@(Model.AnimalAdopcion?.Especie ?? "—")</strong></div>
                <div class="col-md-6">
                    <small class="text-muted d-block"><i class="bi bi-flag me-1"></i>Estado</small>
                    @{
                        var cls = Model.Estado switch { "Aprobada"=>"badge-success-hf","Rechazada"=>"badge-danger-hf",_=>"badge-warning-hf" };
                    }
                    <span class="@cls">@Model.Estado</span>
                </div>
                <div class="col-md-6"><small class="text-muted d-block"><i class="bi bi-calendar3 me-1"></i>Fecha solicitud</small><strong>@Model.FechaSolicitud.ToLocalTime().ToString("dd/MM/yyyy")</strong></div>
            </div>
        </div>
        <div style="padding:16px 24px;border-top:1px solid var(--border);display:flex;gap:10px">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-hf"><i class="bi bi-pencil"></i> Editar</a>
            <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Volver</a>
        </div>
    </div>
</div></div></div></div>
