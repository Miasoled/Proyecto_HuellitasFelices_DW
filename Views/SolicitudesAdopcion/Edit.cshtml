@model HuellitasFelices.Models.SolicitudAdopcion
@{ ViewData["Title"] = "Editar solicitud"; }
<div class="page-header"><div class="container">
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Solicitudes</a></li>
        <li class="breadcrumb-item active">Editar</li>
    </ol></nav>
    <h1><i class="bi bi-pencil-square me-2"></i>Editar solicitud</h1>
</div></div>
<div class="content-wrapper"><div class="container">
<div class="row justify-content-center"><div class="col-lg-7">
    <div class="hf-card">
        <div class="hf-card-header"><i class="bi bi-file-earmark-text me-2"></i>@Model.NombreSolicitante</div>
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FechaCreacion" />
                <input type="hidden" asp-for="FechaSolicitud" />
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="AnimalAdopcionId" class="form-label"><i class="bi bi-house-heart me-1"></i>Animal</label>
                        <select asp-for="AnimalAdopcionId" asp-items="ViewBag.AnimalAdopcionId" class="form-select"></select>
                    </div>
                    <div class="col-12">
                        <label asp-for="NombreSolicitante" class="form-label"><i class="bi bi-person me-1"></i>Nombre del solicitante</label>
                        <input asp-for="NombreSolicitante" class="form-control" />
                        <span asp-validation-for="NombreSolicitante" class="text-danger" style="font-size:.82rem"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Telefono" class="form-label"><i class="bi bi-phone me-1"></i>Teléfono</label>
                        <input asp-for="Telefono" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Estado" class="form-label"><i class="bi bi-flag me-1"></i>Estado</label>
                        <select asp-for="Estado" class="form-select">
                            <option>Pendiente</option><option>Aprobada</option><option>Rechazada</option>
                        </select>
                    </div>
                    <div class="col-12 d-flex gap-3 pt-2">
                        <button type="submit" class="btn-primary-hf"><i class="bi bi-check-lg"></i> Guardar cambios</button>
                        <a asp-action="Index" class="btn-outline-hf"><i class="bi bi-arrow-left"></i> Cancelar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div></div></div></div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
