@model IEnumerable<HuellitasFelices.Models.AnimalAdopcion>
@using HuellitasFelices.ViewModels
@{
    ViewData["Title"] = "Animales en adopción";
    var p = ViewBag.Paginacion as PaginacionViewModel;
}

<div class="page-header">
    <div class="container">
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-2">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
            <li class="breadcrumb-item active">Adopciones</li>
        </ol></nav>
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="bi bi-house-heart-fill me-2"></i>Animales en adopción</h1>
                <small style="opacity:.8">@(p?.TotalRegistros.ToString("N0") ?? "–") animales registrados</small>
            </div>
            @if (User.IsInRole("Administrador") || User.IsInRole("Supervisor") || User.IsInRole("Operador"))
            {
                <a asp-action="Create" class="btn-hero-primary">
                    <i class="bi bi-plus-lg"></i> Nuevo animal
                </a>
            }
        </div>
    </div>
</div>

<div class="content-wrapper">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <form method="get" class="search-bar">
                <input type="text" name="busqueda" value="@p?.Busqueda" class="form-control" placeholder="Buscar por nombre o especie…" />
                <button type="submit" class="btn-search"><i class="bi bi-search"></i></button>
                @if (!string.IsNullOrEmpty(p?.Busqueda))
                {
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-3"><i class="bi bi-x-lg"></i></a>
                }
            </form>

            <div class="d-flex align-items-center gap-3 flex-wrap">
                @if (p != null)
                {
                    <small class="text-muted">Página @p.PaginaActual de @p.TotalPaginas — @p.TotalRegistros.ToString("N0") animales</small>
                }

                @if (User.IsInRole("Administrador") || User.IsInRole("Supervisor") || User.IsInRole("Operador"))
                {
                    <a asp-action="Create"
                       style="background:white; color:var(--primary-dark); border:none;
                              padding:14px 28px; border-radius:16px; font-weight:700;
                              font-size:1rem; text-decoration:none; display:inline-flex;
                              align-items:center; gap:8px; box-shadow:0 2px 12px rgba(0,0,0,.12);
                              transition:transform .2s, box-shadow .2s"
                       onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,.18)'"
                       onmouseout="this.style.transform='';this.style.boxShadow='0 2px 12px rgba(0,0,0,.12)'">
                        <i class="bi bi-plus-lg" style="font-size:1.1rem"></i>
                        Nuevo animal en adopción
                    </a>
                }
            </div>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                var bgColor      = item.Especie == "Perro" ? "#e8f5e9" : item.Especie == "Gato" ? "#e3f2fd" : item.Especie == "Conejo" ? "#fff8e1" : item.Especie == "Ave" ? "#f3e5f5" : "#fce4ec";
                var iconColor    = item.Especie == "Perro" ? "#2e7d32" : item.Especie == "Gato" ? "#1565c0" : item.Especie == "Conejo" ? "#f57f17" : item.Especie == "Ave" ? "#6a1b9a" : "#c62828";
                var animalIcon   = item.Especie == "Perro" ? "bi-patch-heart-fill" : item.Especie == "Gato" ? "bi-moon-stars-fill" : item.Especie == "Conejo" ? "bi-star-fill" : item.Especie == "Ave" ? "bi-feather" : "bi-heart-fill";
                var dispBadge    = item.Disponible ? "badge-success-hf" : "badge-danger-hf";
                var dispText     = item.Disponible ? "En adopción" : "Adoptado";

                <div class="col-6 col-md-4 col-lg-3">
                    <div class="adopcion-animal-card" style="background:white;border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:var(--shadow);transition:transform .3s,box-shadow .3s;height:100%;display:flex;flex-direction:column">
                        <div style="background:@bgColor;height:155px;display:flex;align-items:center;justify-content:center;position:relative;flex-shrink:0;overflow:hidden">
                            @if (!string.IsNullOrEmpty(item.FotoUrl))
                            {
                                <img src="@item.FotoUrl" alt="@item.Nombre"
                                     style="width:100%;height:100%;object-fit:cover" />
                            }
                            else
                            {
                                <!-- Placeholder visual mejorado -->
                                <div style="text-align:center">
                                    <i class="bi @animalIcon" style="font-size:4.5rem;color:@iconColor;opacity:.35;display:block"></i>
                                    <span style="font-size:.75rem;color:@iconColor;opacity:.5;font-weight:600">Sin foto</span>
                                </div>
                            }
                            <div style="position:absolute;top:10px;left:10px">
                                <span class="@dispBadge" style="font-size:.73rem">@dispText</span>
                            </div>
                            <div style="position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,.45);color:white;padding:3px 10px;border-radius:20px;font-size:.73rem;font-weight:600">
                                @item.Especie
                            </div>
                        </div>
                        <div style="padding:14px;flex-grow:1;display:flex;flex-direction:column">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <h6 style="font-weight:800;font-size:.98rem;margin:0">@item.Nombre</h6>
                                <small style="color:var(--text-soft);font-size:.78rem;white-space:nowrap;margin-left:6px">@item.EdadAproximada a.</small>
                            </div>
                            <p style="color:var(--text-soft);font-size:.82rem;margin:0 0 6px">@item.Raza</p>
                            @if (!string.IsNullOrEmpty(item.Descripcion))
                            {
                                <p style="color:var(--text-soft);font-size:.78rem;margin:0 0 10px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;flex-grow:1">@item.Descripcion</p>
                            }
                            else
                            {
                                <div style="flex-grow:1"></div>
                            }
                            <div class="d-flex gap-2 mt-auto">
                                @if (item.Disponible)
                                {
                                    <a asp-controller="SolicitudesAdopcion" asp-action="Create" class="btn-primary-hf flex-grow-1 justify-content-center" style="padding:7px;font-size:.8rem">
                                        <i class="bi bi-heart-fill"></i> Adoptar
                                    </a>
                                }
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-view" style="padding:7px 10px"><i class="bi bi-eye"></i></a>
                                @if (User.IsInRole("Administrador") || User.IsInRole("Supervisor") || User.IsInRole("Operador"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit" style="padding:7px 10px"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete" style="padding:7px 10px"><i class="bi bi-trash"></i></a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-house-heart" style="font-size:4rem;color:var(--border);display:block;margin-bottom:16px"></i>
                    <h5 style="color:var(--text-soft)">No se encontraron animales</h5>
                    @if (!string.IsNullOrEmpty(p?.Busqueda))
                    {
                        <p style="color:var(--text-soft);font-size:.9rem">Sin resultados para "<strong>@p.Busqueda</strong>". <a asp-action="Index">Ver todos</a></p>
                    }
                </div>
            }
        </div>

        @if (p != null) { @await Html.PartialAsync("_Paginacion", p) }
    </div>
</div>
